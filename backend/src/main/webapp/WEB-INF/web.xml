<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.example.servlets.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.example.servlets.RegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>CreateExamServlet</servlet-name>
        <servlet-class>com.example.servlets.CreateExamServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CreateExamServlet</servlet-name>
        <url-pattern>/createExam</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>GetExamServlet</servlet-name>
        <servlet-class>com.example.servlets.GetExamServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>GetExamServlet</servlet-name>
        <url-pattern>/getExam</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>SubmitExamServlet</servlet-name>
        <servlet-class>com.example.servlets.SubmitExamServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SubmitExamServlet</servlet-name>
        <url-pattern>/submitExam</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ResultsServlet</servlet-name>
        <servlet-class>com.example.servlets.ResultsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ResultsServlet</servlet-name>
        <url-pattern>/results</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AdminServlet</servlet-name>
        <servlet-class>com.example.servlets.AdminServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminServlet</servlet-name>
        <url-pattern>/admin</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>StudentServlet</servlet-name>
        <servlet-class>com.example.servlets.StudentServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>StudentServlet</servlet-name>
        <url-pattern>/student</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogActivityServlet</servlet-name>
        <servlet-class>com.example.servlets.LogActivityServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogActivityServlet</servlet-name>
        <url-pattern>/logActivity</url-pattern>
    </servlet-mapping>

</web-app>